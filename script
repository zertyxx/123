local function setUIFade(transparency)
    for _, item in ipairs(uiElements) do
        if item.isLabel then
            item.instance.TextTransparency = transparency
        elseif item.isText then
            item.instance.BackgroundTransparency = transparency
            if item.instance:IsA("TextButton") or item.instance:IsA("TextBox") then
                item.instance.TextTransparency = transparency
            end
            if item.stroke then item.stroke.Transparency = transparency end
        end
    end
end

local function toggleMenuAnimation()
    if animationTweening then return end
    animationTweening = true
    
    if not isMenuOpen then
        MainPanel.Size = UDim2.new(0, 680, 0, 0)
        MainPanel.BackgroundTransparency = 1
        MainStroke.Transparency = 1
        TopBar.BackgroundTransparency = 1
        setUIFade(1)
        MainPanel.Visible = true
        
        TweenService:Create(MainPanel, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, 680, 0, 460), BackgroundTransparency = 0}):Play()
        TweenService:Create(MainStroke, TweenInfo.new(0.4), {Transparency = 0}):Play()
        TweenService:Create(TopBar, TweenInfo.new(0.4), {BackgroundTransparency = 0}):Play()
        
        task.wait(0.1)
        setUIFade(0)
        isMenuOpen = true
        animationTweening = false
        if currentSubTab == "TELEPORT" then refreshPlayerSelectorList() end
    else
        TeamPanel.Visible = false
        isBindingAim, isBindingVis, isBindingMenu, isBindingFly = false, false, false, false
        Aim_Bind.Text = aimbotToggleKey and aimbotToggleKey.Name or "[...]"
        Vis_Bind.Text = visualsToggleKey and visualsToggleKey.Name or "[...]"
