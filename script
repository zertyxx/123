local function createFatalityElement(parent, className, text, placeholder, posY, sizeX, sizeY)
    local element = Instance.new(className)
    element.Size = UDim2.new(0, sizeX, 0, sizeY)
    element.Position = UDim2.new(0, 12, 0, posY)
    element.BackgroundColor3 = fatBgMain
    element.Font = Enum.Font.SourceSans
    element.TextColor3 = Color3.fromRGB(220, 220, 230)
    element.BackgroundTransparency = 0
    element.Parent = parent

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(38, 37, 56)
    stroke.Thickness = 1
    stroke.Transparency = 0
    stroke.Parent = element

    if className == "TextButton" then
        element.Text = text
        element.TextSize = 13
    elseif className == "TextBox" then
        element.Text = text
        element.PlaceholderText = placeholder
        element.TextSize = 13
        element.PlaceholderColor3 = fatTextMuted
        element.ClearTextOnFocus = false
    end

    table.insert(uiElements, {instance = element, stroke = stroke, isText = true, isLabel = false})
    return element
end


