        TweenService:Create(MainPanel, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 680, 0, 0), BackgroundTransparency = 1}):Play()
        TweenService:Create(TopBar, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
