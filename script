        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local files = {}
    if listfiles then
        local success, result = pcall(listfiles, "")
        if success then
            for _, path in ipairs(result) do
                local file = path:match("brutality_(.+)%.json$")
                if file then table.insert(files, file) end
            end
