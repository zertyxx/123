local function isPlayerTargeted(player)
    if player == LocalPlayer then return false end
    local hasSelection = false
    for _, _ in pairs(targetTeams) do hasSelection = true break end
    if not hasSelection then
        if player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then return false end
        return true
    else
        if player.Team and targetTeams[player.Team] then return true end
    end
    return false
end

local function getConfigFile(name)
    return "brutality_" .. tostring(name) .. ".json"
end

local function applyConfigValues()
    local fileName = getConfigFile(selectedConfig)
    if readfile and isfile and isfile(fileName) then
        local data = readfile(fileName)
        local s, decoded = pcall(function() return HttpService:JSONDecode(data) end)
        if s then
            aimbotEnabled = decoded.aimbotEnabled or false
            visualsEnabled = decoded.visualsEnabled or false
            showTracers = decoded.showTracers or false
            showText = decoded.showText or false
            aimbotFOV = decoded.aimbotFOV or 400
            aimbotMaxRange = decoded.aimbotMaxRange or 2000
            currentH = decoded.colorH or currentH
            currentS = decoded.colorS or currentS
            currentV = decoded.colorV or currentV
            
            flyEnabled = decoded.flyEnabled or false
            flySpeed = decoded.flySpeed or 50
            
            if decoded.menuOpenKey then menuOpenKey = Enum.KeyCode[decoded.menuOpenKey] end
            if decoded.aimbotToggleKey then aimbotToggleKey = Enum.KeyCode[decoded.aimbotToggleKey] else aimbotToggleKey = nil end
            if decoded.visualsToggleKey then visualsToggleKey = Enum.KeyCode[decoded.visualsToggleKey] else visualsToggleKey = nil end
            if decoded.flyToggleKey then flyToggleKey = Enum.KeyCode[decoded.flyToggleKey] else flyToggleKey = nil end
            
            Aim_Button.Text = aimbotEnabled and "Aimbot Status: ON" or "Aimbot Status: OFF"
            Aim_Button.TextColor3 = aimbotEnabled and Color3.fromRGB(50, 240, 50) or fatAccent
            Vis_Button.Text = visualsEnabled and "Visuals Status: ON" or "Visuals Status: OFF"
            Vis_Button.TextColor3 = visualsEnabled and Color3.fromRGB(50, 240, 50) or fatAccent
            
            toggleFly(flyEnabled)
            FlySpeed_Input.Text = tostring(flySpeed)
            
            FOV_Input.Text = tostring(aimbotFOV)
            Range_Input.Text = tostring(aimbotMaxRange)
            Tracer_Setting.Text = "Tracers: " .. (showTracers and "ON" or "OFF")
            Text_Setting.Text = "Show Info: " .. (showText and "ON" or "OFF")
            
            Menu_Bind.Text = menuOpenKey.Name
            Aim_Bind.Text = aimbotToggleKey and aimbotToggleKey.Name or "[...]"
            Vis_Bind.Text = visualsToggleKey and visualsToggleKey.Name or "[...]"
            Fly_Bind.Text = flyToggleKey and flyToggleKey.Name or "[...]"
            
            updateColor()
        end
    end
end

local function updateConfigList()
