function refreshPlayerSelectorList()
    for _, child in ipairs(PlayerScroll:GetChildren()) do 
        if child:IsA("TextButton") then child:Destroy() end 
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -6, 0, 28)
            btn.BackgroundColor3 = (selectedTpPlayer == p) and fatBgPanel or fatBgMain
            btn.Font = Enum.Font.SourceSans
            btn.TextSize = 13
            btn.Text = "  👤  " .. p.Name
            
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 1
            stroke.Parent = btn

            if selectedTpPlayer == p then
                btn.TextColor3 = fatAccent
                stroke.Color = fatAccent
            else
                btn.TextColor3 = Color3.fromRGB(180, 180, 190)
                stroke.Color = Color3.fromRGB(45, 45, 55)
            end

            btn.MouseButton1Click:Connect(function()
                selectedTpPlayer = p
                refreshPlayerSelectorList() 
            end)
            btn.Parent = PlayerScroll
        end
    end
    PlayerScroll.CanvasSize = UDim2.new(0, 0, 0, PlayerListLayout.AbsoluteContentSize.Y)
end

