local function updateFlyPhysics()
    if not flyEnabled then return end
    
    local character = LocalPlayer.Character
    local rootPart = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso"))
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if not rootPart or not humanoid then return end
    
    if not bVelocity or bVelocity.Parent ~= rootPart then
        if bVelocity then bVelocity:Destroy() end
        bVelocity = Instance.new("BodyVelocity")
        bVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bVelocity.Velocity = Vector3.new(0, 0, 0)
        bVelocity.Parent = rootPart
    end
    
    if not bGyro or bGyro.Parent ~= rootPart then
        if bGyro then bGyro:Destroy() end
        bGyro = Instance.new("BodyGyro")
        bGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        bGyro.CFrame = rootPart.CFrame
        bGyro.P = 10000
        bGyro.Parent = rootPart
    end
    
    humanoid.PlatformStand = true
    local moveDirection = Vector3.new(0, 0, 0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + Camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - Camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - Camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + Camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + Vector3.new(0, 1, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        moveDirection = moveDirection - Vector3.new(0, 1, 0)
    end
    
    if moveDirection.Magnitude > 0 then
        bVelocity.Velocity = moveDirection.Unit * flySpeed
    else
        bVelocity.Velocity = Vector3.new(0, 0, 0)
    end
    
    bGyro.CFrame = Camera.CFrame
end

local function toggleFly(state)
    if state == nil then flyEnabled = not flyEnabled else flyEnabled = state end
    
    if flyEnabled then
        Fly_Button.Text = "Fly Status: ON"
        Fly_Button.TextColor3 = Color3.fromRGB(50, 240, 50)
        if flyingConnection then flyingConnection:Disconnect() end
        flyingConnection = RunService.Heartbeat:Connect(updateFlyPhysics)
    else
        Fly_Button.Text = "Fly Status: OFF"
        Fly_Button.TextColor3 = fatAccent
        
        if flyingConnection then flyingConnection:Disconnect() flyingConnection = nil end
        if bVelocity then bVelocity:Destroy() bVelocity = nil end
        if bGyro then bGyro:Destroy() bGyro = nil end
        
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

Fly_Button.MouseButton1Click:Connect(function()
    toggleFly()
end)

FlySpeed_Input.FocusLost:Connect(function()
    local val = tonumber(FlySpeed_Input.Text)
    if val then flySpeed = val else FlySpeed_Input.Text = tostring(flySpeed) end
end)


